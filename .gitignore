# ── Secrets — NEVER commit ─────────────────────────────
.env
.env.*
!.env.example

# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
wheels/
*.manifest
*.spec

# ── Virtual environments ───────────────────────────────
venv/
.venv/
env/
ENV/

# ── Tooling / caches ───────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.dmypy.json
.coverage
.coverage.*
htmlcov/
.cache/
.ipynb_checkpoints/

# ── Keystone runtime output ────────────────────────────
logs/*.log
data/*.json
# keep the empty dirs tracked
!logs/.gitkeep
!data/.gitkeep

# stray build artifacts
*.zip

# ── OS / editor cruft ──────────────────────────────────
*:Zone.Identifier
*Zone.Identifier
.DS_Store
Thumbs.db
Desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~
