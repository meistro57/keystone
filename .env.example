# ── Qdrant ─────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

REFLECTIONS_COLLECTION=meta_reflections
MISFIT_COLLECTION=misfit_reports
FINDINGS_COLLECTION=vectoreology_findings
KEYSTONES_COLLECTION=keystones
REFLECTION_VECTOR_NAME=summary_vec

# ── Reflection fields (confirmed) ──────────────────────
R_SUMMARY=summary
R_SOURCE=source_id
R_CONCEPTS=concepts_norm
R_EMPTY=is_empty_reflection
R_CONFIDENCE=reflection_confidence

# ── Misfit rubric (parsed from verdict text) ───────────
M_VERDICT_FIELD=verdict
M_FALLBACK_FIELD=report
RUBRIC_CONSISTENCY=logical_consistency_score
RUBRIC_VALIDITY=re_validity_score
RUBRIC_DRIFT=drift_score

# ── Theme selection ────────────────────────────────────
MIN_MEMBERS=6
MIN_SOURCES=3
COHERENCE_SAMPLE=60
# generic + Gutenberg-license boilerplate; curate from dry_run_scores.json
STOP_CONCEPTS=consciousness,reality,knowledge,truth,existence,mind,understanding,interaction,interpretation,influence,phenomena,derivative works,trademark license,digital distribution,redistribution,copyright,license,electronic works,project gutenberg,public domain,terms of use,digital format,royalty,copyright holder

# ── Convergence scoring ────────────────────────────────
W_CENTRALITY=1.0
W_COHERENCE=1.0
W_SURVIVAL=1.0
SOURCE_SATURATION=20
VERBATIM_CEIL=0.93
VERBATIM_PENALTY=0.4
SURVIVAL_NEUTRAL=0.6
MIN_CONVERGENCE=0.45

# ── LLM routing (OpenRouter) ───────────────────────────
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
SYNTH_MODEL=deepseek/deepseek-r1
CRITIC_MODEL=google/gemma-3-27b-it
LLM_TIMEOUT=180

# ── DeepSeek direct (R1 synthesis) ─────────────────────
# Paste a DeepSeek key to send R1 straight to DeepSeek instead of via OpenRouter.
# Blank = R1 stays on OpenRouter (SYNTH_MODEL above).
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
SYNTH_MODEL_DIRECT=deepseek-reasoner

# Concurrent forge threads (I/O-bound). Lower if you hit provider rate limits.
FORGE_WORKERS=8

# ── Embeddings (match your corpus: gemini-embedding-001, 3072d) ──
EMBED_BASE_URL=https://openrouter.ai/api/v1
EMBED_API_KEY=
EMBED_MODEL=google/gemini-embedding-001
EMBED_DIM=3072
